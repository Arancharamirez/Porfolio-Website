---
import type { Project } from '../data/projects';
import { assetUrl } from '../utils/url';

export interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<!-- Pure background decoration — tiles are not interactive -->
<div class="constellation-wrap" aria-hidden="true">
  {projects.map((p, i) => (
    <div class="constellation-tile" data-index={i}>
      <img
        src={assetUrl(p.hero_image || `/images/projects/${p.slug}/hero.jpg`)}
        alt=""
        loading="eager"
        decoding="async"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <div class="tile-fallback">
        <span>{String(i + 1).padStart(2, '0')}</span>
      </div>
    </div>
  ))}
</div>

<style>
  .constellation-wrap {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 1;
  }

  .constellation-tile {
    position: absolute;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(26, 26, 26, 0.10);
  }

  .constellation-tile img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tile-fallback {
    display: none;
    width: 100%;
    height: 100%;
    background: var(--paper-soft);
    align-items: center;
    justify-content: center;
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  @media (max-width: 767px) {
    .constellation-wrap { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .constellation-tile { animation: none !important; }
  }
</style>

<script>
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reducedMotion) {
    const wrap = document.querySelector('.constellation-wrap');
    if (wrap) {

    const tiles = Array.from(wrap.querySelectorAll('.constellation-tile'));

    const aspectRatios = [1.3, 0.78, 1.0, 1.25, 0.82, 1.1, 1.35, 0.75, 1.0, 1.2];
    const widths       = [230, 270, 195, 310, 240, 205, 285, 250, 185, 260];

    // Fixed layout — [left %, top %, rotation deg]
    // Tiles placed around the perimeter, clear of the centre text block
    const positions = [
      [ 1,  6, -6],   // top-left corner
      [11,  2,  4],   // top, left of centre
      [70,  2, -5],   // top, right of centre
      [82,  6,  6],   // top-right corner
      [84, 42, -7],   // right edge, upper
      [81, 65,  4],   // right edge, lower
      [61, 78, -8],   // bottom, right of centre
      [10, 76,  5],   // bottom, left of centre
      [ 1, 52, -4],   // left edge, lower
      [ 2, 24,  7],   // left edge, upper
    ];

    // Deterministic drift — same every page load, no Math.random()
    const durations = [9000, 11500, 8200, 13000, 10800, 9600, 12200, 10000, 8800, 11000];
    const dxValues  = [ 18, -22,  14, -20,  24, -16,  20, -18,  16, -24];
    const dyValues  = [-14,  18, -12,  16, -20,  14, -16,  12, -18,  20];
    const drValues  = [  2,  -2, 1.5,  -2.5, 2, -1.5, 2.5,  -2, 1.5,  -2];
    const delays    = [  0, -3200, -6500, -1800, -8000, -4500, -2200, -7000, -5500, -3800];

    tiles.forEach((tile, i) => {
      const tw = widths[i % widths.length];
      const th = Math.round(tw * aspectRatios[i % aspectRatios.length]);
      const [lp, tp, rot] = positions[i % positions.length];

      tile.style.width     = tw + 'px';
      tile.style.height    = th + 'px';
      tile.style.left      = lp + '%';
      tile.style.top       = tp + '%';
      tile.style.transform = `rotate(${rot}deg)`;

      const dur   = durations[i % durations.length];
      const dx    = dxValues[i % dxValues.length];
      const dy    = dyValues[i % dyValues.length];
      const dr    = drValues[i % drValues.length];
      const delay = delays[i % delays.length];

      tile.animate(
        [
          { transform: `translate(0px, 0px) rotate(${rot}deg)` },
          { transform: `translate(${dx}px, ${dy}px) rotate(${rot + dr}deg)` },
        ],
        {
          duration: dur,
          iterations: Infinity,
          direction: 'alternate',
          easing: 'ease-in-out',
          delay,
          fill: 'both',
        }
      );
    });
    } // end if (wrap)
  }
</script>
