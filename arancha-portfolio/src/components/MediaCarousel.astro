---
export interface Slide {
  type: 'image' | 'video' | 'grid';
  src?: string;
  srcs?: string[];  // for grid type (2 images side by side)
  alt?: string;
}

export interface Props {
  slides: Slide[];
  label?: string;
}

const { slides, label = 'Project media' } = Astro.props;
---

<div class="carousel" aria-label={label} role="region">
  <div class="carousel-track" id="carousel-track">
    {slides.map((slide, i) => (
      <div class="carousel-slide" role="group" aria-label={`Slide ${i + 1} of ${slides.length}`}>
        {slide.type === 'image' && (
          <img
            src={slide.src}
            alt={slide.alt ?? ''}
            loading="lazy"
            decoding="async"
            onerror="this.parentElement.style.background='var(--paper-soft)'"
          />
        )}
        {slide.type === 'video' && (
          <video src={slide.src} autoplay muted loop playsinline />
        )}
        {slide.type === 'grid' && slide.srcs && (
          <div class="slide-grid">
            {slide.srcs.map((s, j) => (
              <img src={s} alt={`Detail ${j + 1}`} loading="lazy" decoding="async" />
            ))}
          </div>
        )}
      </div>
    ))}
  </div>

  <button class="carousel-btn prev" aria-label="Previous slide" id="carousel-prev">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M12 4L6 10l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <button class="carousel-btn next" aria-label="Next slide" id="carousel-next">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M8 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="carousel-dots" role="tablist" aria-label="Slides">
    {slides.map((_, i) => (
      <button
        class:list={['dot', i === 0 && 'active']}
        role="tab"
        aria-selected={i === 0}
        aria-label={`Go to slide ${i + 1}`}
        data-slide-index={i}
      />
    ))}
  </div>
</div>

<style>
  .carousel {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-hero);
    background: var(--paper-soft);
    user-select: none;
  }

  .carousel-track {
    display: flex;
    scroll-snap-type: x mandatory;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }
  .carousel-track::-webkit-scrollbar { display: none; }

  .carousel-slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .carousel-slide img,
  .carousel-slide video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .slide-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    height: 100%;
  }
  .slide-grid img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: rgba(244, 241, 234, 0.9);
    border: 1px solid var(--rule);
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 200ms ease;
    cursor: pointer;
    z-index: 5;
  }
  .carousel:hover .carousel-btn {
    opacity: 1;
  }
  .carousel-btn.prev { left: 1rem; }
  .carousel-btn.next { right: 1rem; }
  .carousel-btn:hover {
    background: var(--paper);
  }

  .carousel-dots {
    position: absolute;
    bottom: 0.875rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.4rem;
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(26, 26, 26, 0.25);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 200ms ease, transform 200ms ease;
  }
  .dot.active {
    background: var(--ink);
    transform: scale(1.3);
  }
</style>

<script>
  (() => {
    const carousels = document.querySelectorAll<HTMLElement>('.carousel');
    carousels.forEach((carousel) => {
      const track = carousel.querySelector<HTMLElement>('.carousel-track')!;
      const prevBtn = carousel.querySelector<HTMLButtonElement>('.prev')!;
      const nextBtn = carousel.querySelector<HTMLButtonElement>('.next')!;
      const dots = carousel.querySelectorAll<HTMLButtonElement>('.dot');
      let current = 0;
      const total = dots.length;

      function goTo(i: number) {
        current = (i + total) % total;
        const slideWidth = track.clientWidth;
        track.scrollTo({ left: current * slideWidth, behavior: 'smooth' });
        dots.forEach((d, idx) => {
          d.classList.toggle('active', idx === current);
          d.setAttribute('aria-selected', String(idx === current));
        });
      }

      prevBtn?.addEventListener('click', () => goTo(current - 1));
      nextBtn?.addEventListener('click', () => goTo(current + 1));
      dots.forEach((dot) => {
        dot.addEventListener('click', () => goTo(parseInt(dot.dataset.slideIndex ?? '0')));
      });

      // Keyboard nav
      carousel.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'ArrowLeft') goTo(current - 1);
        if (e.key === 'ArrowRight') goTo(current + 1);
      });

      // Sync dots on scroll
      track.addEventListener('scroll', () => {
        const idx = Math.round(track.scrollLeft / track.clientWidth);
        if (idx !== current) {
          current = idx;
          dots.forEach((d, i) => d.classList.toggle('active', i === current));
        }
      }, { passive: true });
    });
  })();
</script>
